   9+ 99A7 CD 47 9C     	call Prepara_draw
  10+ 99AA 7C           	ld a,h 						 					; El objeto existe, o se está iniciando?. Si se está iniciando, (Posicion_inicio = Posicion_actual) y saltamos_
  11+ 99AB A7           	and a 											; _a la subrutina [Inicializacion] donde asignaremos cuadrante y límites.
  12+ 99AC 28 05        	jr z,2F
  13+ 99AE
  14+ 99AE 3A 09 8C     	ld a,(Cuad_objeto)			 					; El objeto ya se inició. Cargamos en A el cuadrante de pantalla en el que lo hizo y saltamos a 1F.
  15+ 99B1 18 0C        	jr 1F
  16+ 99B3
  17+ 99B3 2A 07 8C     2 ld hl,(Posicion_inicio) 							; No hay (Posicion_actual), por lo que el objeto se está iniciando.
  18+ 99B6 22 FA 8B     	ld (Posicion_actual),hl							; Indicamos que (Posicion_actual) = (Posicion_inicio) y saltamos a la subrutina [Inicializacion], (donde asignaremos_
  19+ 99B9 CD 45 9B     	call Inicializacion   							; _(Limite_horizontal), (Limite_vertical) y (Cuad_objeto). También asignaremos las coordenadas X e Y. (Posición 0,0)_
  20+ 99BC              ;													; _la esquina superior izquierda de la pantalla.
  21+ 99BC
  22+ 99BC CD B5 A0     	call Inicia_Puntero_mov							; El objeto está inicializado. Antes de salir inicializamos tb el puntero de movimiento de la entidad.
  23+ 99BF
  24+ 99BF 3A F7 8B     1 ld a,(Ctrl_0)
  25+ 99C2 CB 6F        	bit 5,a
  26+ 99C4 20 06        	jr nz,3F										; Si acabamos de inicializar un objeto, NO COMPROBAMOS LÍMITES.
  27+ 99C6
  28+ 99C6 CD DB 99     	call Comprueba_limite_horizontal
  29+ 99C9 CD 6B 9A     	call Comprueba_limite_vertical
  30+ 99CC
  31+ 99CC              ; Llegados a este punto, tengo Filas/Columnas en BC y (Cuad_objeto) en A´.
  32+ 99CC              ; -----------------------
  33+ 99CC              ; -----------------------
  34+ 99CC              ; -----------------------
  35+ 99CC
  36+ 99CC CD C1 9B     3 call calcula_CColumnass							; Define el valor de la variable (Columnas). Nº de columnas que se van a pintar de la entidad.
  37+ 99CF CD F2 9B     	call Calcula_puntero_de_impresion				; Después de ejecutar esta rutina tenemos el puntero de impresión en HL.
  38+ 99D2
  39+ 99D2 3A F7 8B     	ld a,(Ctrl_0)									; Antes de salir de la rutina REStauramos el bit5 de Ctrl_0 para que nos vuelva_
  40+ 99D5 CB AF        	res 5,a											; _a ser de utilidad.
  41+ 99D7 32 F7 8B     	ld (Ctrl_0),a
