   5+ 93FE              ;   Construyo un nº aleatorio. Método: "DERIVANDO."
   6+ 93FE              ;   (XOR) bit a bit.
   7+ 93FE              ;
   8+ 93FE              ;   INPUTS: B contendrá el nº de números aleatorios que queremos generar, (0-$ff).
   9+ 93FE
  10+ 93FE              Derivando_RND
  11+ 93FE
  12+ 93FE 21 F6 88         ld hl,Numeros_aleatorios
  13+ 9401
  14+ 9401 ED 5F        3 ld a,r      			                ; La semilla inicial de nuestro nº aleatorio la proporciona el registro `R´. Cargamos A con R.
  15+ 9403 C5               push bc
  16+ 9404              ;                                       ; El registro R, es un registro de 8 bits que actúa como contador de refresco de la memoria dinámica. ($00 - $ff).
  17+ 9404 01 00 07         ld bc,$0700                         ; C contendrá nuestro nº aleatorio: $0 - $ff. Inicialmente está a "0".
  18+ 9407              ;                                       ; B actuará como contador de bits. Requerimos de 1 byte, ($ff).
  19+ 9407
  20+ 9407 A7           6 and a                                 ; Carry a "0".
  21+ 9408 CB 3F            srl a                               ; Desplazamiento a la derecha.
  22+ 940A 30 02            jr nc,1F
  23+ 940C
  24+ 940C CB C1            set 0,c
  25+ 940E
  26+ 940E 57           1 ld d,a                                ; D contiene la copia de nuestra semilla después del DESPLAZAMIENTO.
  27+ 940F E6 01            and %00000001                       ; Extraigo el último bit de A y lo guardamos en E.
  28+ 9411 5F               ld e,a
  29+ 9412
  30+ 9412 7A               ld a,d
  31+ 9413 E6 02            and %00000010                       ; Extraigo el penúltimo bit de A y lo `traslado´ al último bit de A. El objetivo es implementar una función XOR_
  32+ 9415 28 02            jr z,2F                             ; _con el último y penúltimo bit de nuestra semilla.
  33+ 9417
  34+ 9417 CB 3F            srl a
  35+ 9419
  36+ 9419 AB           2 xor e                                 ; XOR entre el último y penúltimo bit de A.
  37+ 941A
  38+ 941A 7A               ld a,d                              ; A vuelve a contener la copia de nuestra semilla después del DESPLAZAMIENTO.
  39+ 941B 28 04            jr z,4F
  40+ 941D
  41+ 941D CB FF            set 7,a
  42+ 941F 18 02            jr 5F
  43+ 9421
  44+ 9421 CB BF        4 res 7,a
  45+ 9423
  46+ 9423 CB 21        5 sla c
  47+ 9425 10 E0            djnz 6B
  48+ 9427
  49+ 9427 79               ld a,c                              ; Nº aleatorio (1 Byte) en A.
  50+ 9428
  51+ 9428 77               ld (hl),a
  52+ 9429 23               inc hl
  53+ 942A C1               pop bc
  54+ 942B 10 D4            djnz 3B
  55+ 942D
  56+ 942D C9               ret
