  15+ 95D5              ;			 6 ..... AMARILLO
  16+ 95D5              ; 			 7 ..... BLANCO
  17+ 95D5              ;
  18+ 95D5              ;	INPUT: A contiene los atributos de pantalla.
  19+ 95D5              ;
