   5+ 93CF              ;   Construyo un nº aleatorio. Método: "DERIVANDO."
   6+ 93CF              ;   (XOR) bit a bit.
   7+ 93CF              ;
   8+ 93CF              ;   INPUTS: B contendrá el nº de números aleatorios que queremos generar, (0-$ff).
   9+ 93CF
  10+ 93CF              Derivando_RND
  11+ 93CF
  12+ 93CF 21 F6 88         ld hl,Numeros_aleatorios
  13+ 93D2
  14+ 93D2 ED 5F        3 ld a,r      			                ; La semilla inicial de nuestro nº aleatorio la proporciona el registro `R´. Cargamos A con R.
  15+ 93D4 C5               push bc
  16+ 93D5              ;                                       ; El registro R, es un registro de 8 bits que actúa como contador de refresco de la memoria dinámica. ($00 - $ff).
  17+ 93D5 01 00 07         ld bc,$0700                         ; C contendrá nuestro nº aleatorio: $0 - $ff. Inicialmente está a "0".
  18+ 93D8              ;                                       ; B actuará como contador de bits. Requerimos de 1 byte, ($ff).
  19+ 93D8
  20+ 93D8 A7           6 and a                                 ; Carry a "0".
  21+ 93D9 CB 3F            srl a                               ; Desplazamiento a la derecha.
  22+ 93DB 30 02            jr nc,1F
  23+ 93DD
  24+ 93DD CB C1            set 0,c
  25+ 93DF
  26+ 93DF 57           1 ld d,a                                ; D contiene la copia de nuestra semilla después del DESPLAZAMIENTO.
  27+ 93E0 E6 01            and %00000001                       ; Extraigo el último bit de A y lo guardamos en E.
  28+ 93E2 5F               ld e,a
  29+ 93E3
  30+ 93E3 7A               ld a,d
  31+ 93E4 E6 02            and %00000010                       ; Extraigo el penúltimo bit de A y lo `traslado´ al último bit de A. El objetivo es implementar una función XOR_
  32+ 93E6 28 02            jr z,2F                             ; _con el último y penúltimo bit de nuestra semilla.
  33+ 93E8
  34+ 93E8 CB 3F            srl a
  35+ 93EA
  36+ 93EA AB           2 xor e                                 ; XOR entre el último y penúltimo bit de A.
  37+ 93EB
  38+ 93EB 7A               ld a,d                              ; A vuelve a contener la copia de nuestra semilla después del DESPLAZAMIENTO.
  39+ 93EC 28 04            jr z,4F
  40+ 93EE
  41+ 93EE CB FF            set 7,a
  42+ 93F0 18 02            jr 5F
  43+ 93F2
  44+ 93F2 CB BF        4 res 7,a
  45+ 93F4
  46+ 93F4 CB 21        5 sla c
  47+ 93F6 10 E0            djnz 6B
  48+ 93F8
  49+ 93F8 79               ld a,c                              ; Nº aleatorio (1 Byte) en A.
  50+ 93F9
  51+ 93F9 77               ld (hl),a
  52+ 93FA 23               inc hl
  53+ 93FB C1               pop bc
  54+ 93FC 10 D4            djnz 3B
  55+ 93FE
  56+ 93FE C9               ret
