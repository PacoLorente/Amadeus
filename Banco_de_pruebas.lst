   6+ 999C
   7+ 999C              Draw
   8+ 999C
   9+ 999C CD 42 9C     	call Prepara_draw
  10+ 999F 7C           	ld a,h 						 					; El objeto existe, o se está iniciando?. Si se está iniciando, (Posicion_inicio = Posicion_actual) y saltamos_
  11+ 99A0 A7           	and a 											; _a la subrutina [Inicializacion] donde asignaremos cuadrante y límites.
  12+ 99A1 28 05        	jr z,2F
  13+ 99A3
  14+ 99A3 3A 09 8C     	ld a,(Cuad_objeto)			 					; El objeto ya se inició. Cargamos en A el cuadrante de pantalla en el que lo hizo y saltamos a 1F.
  15+ 99A6 18 0C        	jr 1F
  16+ 99A8
  17+ 99A8 2A 07 8C     2 ld hl,(Posicion_inicio) 							; No hay (Posicion_actual), por lo que el objeto se está iniciando.
  18+ 99AB 22 FA 8B     	ld (Posicion_actual),hl							; Indicamos que (Posicion_actual) = (Posicion_inicio) y saltamos a la subrutina [Inicializacion], (donde asignaremos_
  19+ 99AE CD 3A 9B     	call Inicializacion   							; _(Limite_horizontal), (Limite_vertical) y (Cuad_objeto). También asignaremos las coordenadas X e Y. (Posición 0,0)_
  20+ 99B1              ;													; _la esquina superior izquierda de la pantalla.
  21+ 99B1
  22+ 99B1 CD B2 A0     	call Inicia_Puntero_mov							; El objeto está inicializado. Antes de salir inicializamos tb el puntero de movimiento de la entidad.
  23+ 99B4
  24+ 99B4 3A F7 8B     1 ld a,(Ctrl_0)
  25+ 99B7 CB 6F        	bit 5,a
  26+ 99B9 20 06        	jr nz,3F										; Si acabamos de inicializar un objeto, NO COMPROBAMOS LÍMITES.
  27+ 99BB
  28+ 99BB CD D0 99     	call Comprueba_limite_horizontal
  29+ 99BE CD 60 9A     	call Comprueba_limite_vertical
  30+ 99C1
  31+ 99C1              ; Llegados a este punto, tengo Filas/Columnas en BC y (Cuad_objeto) en A´.
  32+ 99C1              ; -----------------------
  33+ 99C1              ; -----------------------
  34+ 99C1              ; -----------------------
  35+ 99C1
  36+ 99C1 CD B6 9B     3 call calcula_CColumnass							; Define el valor de la variable (Columnas). Nº de columnas que se van a pintar de la entidad.
  37+ 99C4 CD ED 9B     	call Calcula_puntero_de_impresion				; Después de ejecutar esta rutina tenemos el puntero de impresión en HL.
  38+ 99C7
  39+ 99C7 3A F7 8B     	ld a,(Ctrl_0)									; Antes de salir de la rutina REStauramos el bit5 de Ctrl_0 para que nos vuelva_
  40+ 99CA CB AF        	res 5,a											; _a ser de utilidad.
  41+ 99CC 32 F7 8B     	ld (Ctrl_0),a
  42+ 99CF
  43+ 99CF C9           	ret
  44+ 99D0
  45+ 99D0              ; *******************************************************************************************************************************************************************************************
  46+ 99D0              ;	21/01/23
  47+ 99D0              ;
  48+ 99D0              ; 	Comprueba_limite_horizontal.
  49+ 99D0              ;
  50+ 99D0              ;	La rutina comprueba si hemos sobrepasado el (Limite_horizontal) definido en la rutina [Inicializacion]. Este será:_
  51+ 99D0              ;	_ $4fc0 si partimos de los cuadrantes 1 o 2 de pantalla o $4820 si partimos de los cuadrantes 3 o 4.
  52+ 99D0              ;
  53+ 99D0              ;	Si sobrepasamos o alcanzamos el límite horizontal establecido, la rutina cargará el registro E con un "1".
  54+ 99D0              ;	Si NO HEMOS SOBREPASADO (Limite_horizontal), E="0".
  55+ 99D0              ;	E="1" indica que HEMOS SOBREPASADO el (Limite_horizontal).
  56+ 99D0              ;	E="2" indica que NO HEMOS SOBREPASADO el (Limite_horizontal) pero hemos alcanzado o superado EL CENTRO DE PANTALLA.
  57+ 99D0
  58+ 99D0
  59+ 99D0
  60+ 99D0 3A F7 8B     Comprueba_limite_horizontal ld a,(Ctrl_0)          	; Si no hemos desaparecido por arriba o por abajo, saltamos a 1F para comprobar_
  61+ 99D3 CB 57        	bit 2,a                                         ; _si hemos llegado o sobrepasado (Limite_horizontal). Seguimos con la rutina.
