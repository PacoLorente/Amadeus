   4+ 93DE              ;
   5+ 93DE              ;   Construyo un nº aleatorio. Método: "DERIVANDO."
   6+ 93DE              ;   (XOR) bit a bit.
   7+ 93DE              ;
   8+ 93DE              ;   INPUTS: B contendrá el nº de números aleatorios que queremos generar, (0-$ff).
   9+ 93DE
  10+ 93DE              Derivando_RND
  11+ 93DE
  12+ 93DE 21 F6 88         ld hl,Numeros_aleatorios
  13+ 93E1
  14+ 93E1 ED 5F        3 ld a,r      			                ; La semilla inicial de nuestro nº aleatorio la proporciona el registro `R´. Cargamos A con R.
  15+ 93E3 C5               push bc
  16+ 93E4              ;                                       ; El registro R, es un registro de 8 bits que actúa como contador de refresco de la memoria dinámica. ($00 - $ff).
  17+ 93E4 01 00 07         ld bc,$0700                         ; C contendrá nuestro nº aleatorio: $0 - $ff. Inicialmente está a "0".
  18+ 93E7              ;                                       ; B actuará como contador de bits. Requerimos de 1 byte, ($ff).
  19+ 93E7
  20+ 93E7 A7           6 and a                                 ; Carry a "0".
  21+ 93E8 CB 3F            srl a                               ; Desplazamiento a la derecha.
  22+ 93EA 30 02            jr nc,1F
  23+ 93EC
  24+ 93EC CB C1            set 0,c
  25+ 93EE
  26+ 93EE 57           1 ld d,a                                ; D contiene la copia de nuestra semilla después del DESPLAZAMIENTO.
  27+ 93EF E6 01            and %00000001                       ; Extraigo el último bit de A y lo guardamos en E.
  28+ 93F1 5F               ld e,a
  29+ 93F2
  30+ 93F2 7A               ld a,d
  31+ 93F3 E6 02            and %00000010                       ; Extraigo el penúltimo bit de A y lo `traslado´ al último bit de A. El objetivo es implementar una función XOR_
  32+ 93F5 28 02            jr z,2F                             ; _con el último y penúltimo bit de nuestra semilla.
  33+ 93F7
  34+ 93F7 CB 3F            srl a
  35+ 93F9
  36+ 93F9 AB           2 xor e                                 ; XOR entre el último y penúltimo bit de A.
  37+ 93FA
  38+ 93FA 7A               ld a,d                              ; A vuelve a contener la copia de nuestra semilla después del DESPLAZAMIENTO.
  39+ 93FB 28 04            jr z,4F
  40+ 93FD
  41+ 93FD CB FF            set 7,a
  42+ 93FF 18 02            jr 5F
  43+ 9401
  44+ 9401 CB BF        4 res 7,a
  45+ 9403
  46+ 9403 CB 21        5 sla c
  47+ 9405 10 E0            djnz 6B
  48+ 9407
  49+ 9407 79               ld a,c                              ; Nº aleatorio (1 Byte) en A.
  50+ 9408
  51+ 9408 77               ld (hl),a
  52+ 9409 23               inc hl
  53+ 940A C1               pop bc
  54+ 940B 10 D4            djnz 3B
  55+ 940D
  56+ 940D C9               ret
  57+ 940E
  58+ 940E
  59+ 940E
