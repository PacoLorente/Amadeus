2393  99AA              	include "Draw_XOR.asm"
# file opened: Draw_XOR.asm
   1+ 99AA              ; ******************************************************************************************************************************************************************************************
   2+ 99AA              ;
   3+ 99AA              ; 26/06/23
   4+ 99AA              ;
   5+ 99AA              ; DRAW. ************************************************************************************************************************************************************************************
   6+ 99AA
   7+ 99AA              Draw
   8+ 99AA
   9+ 99AA CD 50 9C     	call Prepara_draw
  10+ 99AD 7C           	ld a,h 						 					; El objeto existe, o se está iniciando?. Si se está iniciando, (Posicion_inicio = Posicion_actual) y saltamos_
  11+ 99AE A7           	and a 											; _a la subrutina [Inicializacion] donde asignaremos cuadrante y límites.
  12+ 99AF 28 05        	jr z,2F
  13+ 99B1
  14+ 99B1 3A 09 8C     	ld a,(Cuad_objeto)			 					; El objeto ya se inició. Cargamos en A el cuadrante de pantalla en el que lo hizo y saltamos a 1F.
  15+ 99B4 18 0C        	jr 1F
  16+ 99B6
  17+ 99B6 2A 07 8C     2 ld hl,(Posicion_inicio) 							; No hay (Posicion_actual), por lo que el objeto se está iniciando.
  18+ 99B9 22 FA 8B     	ld (Posicion_actual),hl							; Indicamos que (Posicion_actual) = (Posicion_inicio) y saltamos a la subrutina [Inicializacion], (donde asignaremos_
  19+ 99BC CD 48 9B     	call Inicializacion   							; _(Limite_horizontal), (Limite_vertical) y (Cuad_objeto). También asignaremos las coordenadas X e Y. (Posición 0,0)_
  20+ 99BF              ;													; _la esquina superior izquierda de la pantalla.
  21+ 99BF
  22+ 99BF CD BF A0     	call Inicia_Puntero_mov							; El objeto está inicializado. Antes de salir inicializamos tb el puntero de movimiento de la entidad.
  23+ 99C2
  24+ 99C2 3A F7 8B     1 ld a,(Ctrl_0)
  25+ 99C5 CB 6F        	bit 5,a
  26+ 99C7 20 06        	jr nz,3F										; Si acabamos de inicializar un objeto, NO COMPROBAMOS LÍMITES.
  27+ 99C9
  28+ 99C9 CD DE 99     	call Comprueba_limite_horizontal
  29+ 99CC CD 6E 9A     	call Comprueba_limite_vertical
  30+ 99CF
  31+ 99CF              ; Llegados a este punto, tengo Filas/Columnas en BC y (Cuad_objeto) en A´.
  32+ 99CF              ; -----------------------
  33+ 99CF              ; -----------------------
  34+ 99CF              ; -----------------------
  35+ 99CF
  36+ 99CF CD C4 9B     3 call calcula_CColumnass							; Define el valor de la variable (Columnas). Nº de columnas que se van a pintar de la entidad.
  37+ 99D2 CD FB 9B     	call Calcula_puntero_de_impresion				; Después de ejecutar esta rutina tenemos el puntero de impresión en HL.
  38+ 99D5
  39+ 99D5 3A F7 8B     	ld a,(Ctrl_0)									; Antes de salir de la rutina REStauramos el bit5 de Ctrl_0 para que nos vuelva_
  40+ 99D8 CB AF        	res 5,a											; _a ser de utilidad.
  41+ 99DA 32 F7 8B     	ld (Ctrl_0),a
  42+ 99DD
  43+ 99DD C9           	ret
  44+ 99DE
  45+ 99DE              ; *******************************************************************************************************************************************************************************************
  46+ 99DE              ;	21/01/23
  47+ 99DE              ;
  48+ 99DE              ; 	Comprueba_limite_horizontal.
  49+ 99DE              ;
  50+ 99DE              ;	La rutina comprueba si hemos sobrepasado el (Limite_horizontal) definido en la rutina [Inicializacion]. Este será:_
  51+ 99DE              ;	_ $4fc0 si partimos de los cuadrantes 1 o 2 de pantalla o $4820 si partimos de los cuadrantes 3 o 4.
