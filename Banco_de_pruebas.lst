   1+ 95E1              ; *********************************** Limpia la pantalla, CLEAR SCREEN ****************************************************************
   2+ 95E1              ;
   3+ 95E1              ;
   4+ 95E1              ;	CLS.
   5+ 95E1              ;
   6+ 95E1              ;	Limpia la pantalla y define sus atributos.
   7+ 95E1              ;	El formato: FBPPPIII (Flash, Brillo, Papel, Tinta).
   8+ 95E1              ;
   9+ 95E1              ;	COLORES: 0 ..... NEGRO
  10+ 95E1              ;    		 1 ..... AZUL
  11+ 95E1              ; 			 2 ..... ROJO
  12+ 95E1              ;			 3 ..... MAGENTA
  13+ 95E1              ; 			 4 ..... VERDE
  14+ 95E1              ; 			 5 ..... CIAN
  15+ 95E1              ;			 6 ..... AMARILLO
  16+ 95E1              ; 			 7 ..... BLANCO
  17+ 95E1              ;
  18+ 95E1              ;	INPUT: A contiene los atributos de pantalla.
  19+ 95E1              ;
  20+ 95E1              ;	DESTRUIDOS: F,BC,DE,HL !!!!!
  21+ 95E1
  22+ 95E1
  23+ 95E1 21 00 40     Cls LD HL,$4000											; HL => Comienzo de pantalla.
  24+ 95E4 11 01 40     	LD DE,$4001
  25+ 95E7 01 00 18     	LD BC,6144											; Tamaño de la pantalla, $17ff
  26+ 95EA 36 00        	LD (HL),0 											; Ponemos a "0" todos los pixels de la pantalla.
  27+ 95EC ED B0        	LDIR
  28+ 95EE 01 FF 02     	LD BC,767
  29+ 95F1 77           	LD (HL),a						 					; Atributos de pantalla, % 00 xxx xxx en [A].
  30+ 95F2 ED B0        	LDIR
  31+ 95F4 C9           	ret
  32+ 95F5
