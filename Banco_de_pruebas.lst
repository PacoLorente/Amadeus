   5+ 93FF              ;   Construyo un nº aleatorio. Método: "DERIVANDO."
   6+ 93FF              ;   (XOR) bit a bit.
   7+ 93FF              ;
   8+ 93FF              ;   INPUTS: B contendrá el nº de números aleatorios que queremos generar, (0-$ff).
   9+ 93FF
  10+ 93FF              Derivando_RND
  11+ 93FF
  12+ 93FF 21 F6 88         ld hl,Numeros_aleatorios
  13+ 9402
  14+ 9402 ED 5F        3 ld a,r      			                ; La semilla inicial de nuestro nº aleatorio la proporciona el registro `R´. Cargamos A con R.
  15+ 9404 C5               push bc
  16+ 9405              ;                                       ; El registro R, es un registro de 8 bits que actúa como contador de refresco de la memoria dinámica. ($00 - $ff).
  17+ 9405 01 00 07         ld bc,$0700                         ; C contendrá nuestro nº aleatorio: $0 - $ff. Inicialmente está a "0".
  18+ 9408              ;                                       ; B actuará como contador de bits. Requerimos de 1 byte, ($ff).
  19+ 9408
  20+ 9408 A7           6 and a                                 ; Carry a "0".
  21+ 9409 CB 3F            srl a                               ; Desplazamiento a la derecha.
  22+ 940B 30 02            jr nc,1F
  23+ 940D
  24+ 940D CB C1            set 0,c
  25+ 940F
  26+ 940F 57           1 ld d,a                                ; D contiene la copia de nuestra semilla después del DESPLAZAMIENTO.
  27+ 9410 E6 01            and %00000001                       ; Extraigo el último bit de A y lo guardamos en E.
  28+ 9412 5F               ld e,a
  29+ 9413
  30+ 9413 7A               ld a,d
  31+ 9414 E6 02            and %00000010                       ; Extraigo el penúltimo bit de A y lo `traslado´ al último bit de A. El objetivo es implementar una función XOR_
  32+ 9416 28 02            jr z,2F                             ; _con el último y penúltimo bit de nuestra semilla.
  33+ 9418
  34+ 9418 CB 3F            srl a
  35+ 941A
  36+ 941A AB           2 xor e                                 ; XOR entre el último y penúltimo bit de A.
  37+ 941B
  38+ 941B 7A               ld a,d                              ; A vuelve a contener la copia de nuestra semilla después del DESPLAZAMIENTO.
  39+ 941C 28 04            jr z,4F
  40+ 941E
  41+ 941E CB FF            set 7,a
  42+ 9420 18 02            jr 5F
  43+ 9422
  44+ 9422 CB BF        4 res 7,a
  45+ 9424
  46+ 9424 CB 21        5 sla c
  47+ 9426 10 E0            djnz 6B
  48+ 9428
  49+ 9428 79               ld a,c                              ; Nº aleatorio (1 Byte) en A.
  50+ 9429
  51+ 9429 77               ld (hl),a
  52+ 942A 23               inc hl
  53+ 942B C1               pop bc
  54+ 942C 10 D4            djnz 3B
  55+ 942E
  56+ 942E C9               ret
  57+ 942F
  58+ 942F
  59+ 942F
