 351+ 9B68              ;
 352+ 9B68              ;	INPUT: [HL] contendrá la dirección de pantalla a la que queremos asignar cuadrante. HL=(Posicion_inicio).
 353+ 9B68              ; 		   [BC] contendrá (Filas)/(Columns) del objeto a inicializar.
 354+ 9B68              ; 		   [E] ="0"
 355+ 9B68
