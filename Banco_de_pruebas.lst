   5+ 93DB              ;   Construyo un nº aleatorio. Método: "DERIVANDO."
   6+ 93DB              ;   (XOR) bit a bit.
   7+ 93DB              ;
   8+ 93DB              ;   INPUTS: B contendrá el nº de números aleatorios que queremos generar, (0-$ff).
   9+ 93DB
  10+ 93DB              Derivando_RND
  11+ 93DB
  12+ 93DB 21 F6 88         ld hl,Numeros_aleatorios
  13+ 93DE
  14+ 93DE ED 5F        3 ld a,r      			                ; La semilla inicial de nuestro nº aleatorio la proporciona el registro `R´. Cargamos A con R.
  15+ 93E0 C5               push bc
  16+ 93E1              ;                                       ; El registro R, es un registro de 8 bits que actúa como contador de refresco de la memoria dinámica. ($00 - $ff).
  17+ 93E1 01 00 07         ld bc,$0700                         ; C contendrá nuestro nº aleatorio: $0 - $ff. Inicialmente está a "0".
  18+ 93E4              ;                                       ; B actuará como contador de bits. Requerimos de 1 byte, ($ff).
  19+ 93E4
  20+ 93E4 A7           6 and a                                 ; Carry a "0".
  21+ 93E5 CB 3F            srl a                               ; Desplazamiento a la derecha.
  22+ 93E7 30 02            jr nc,1F
  23+ 93E9
  24+ 93E9 CB C1            set 0,c
  25+ 93EB
  26+ 93EB 57           1 ld d,a                                ; D contiene la copia de nuestra semilla después del DESPLAZAMIENTO.
  27+ 93EC E6 01            and %00000001                       ; Extraigo el último bit de A y lo guardamos en E.
  28+ 93EE 5F               ld e,a
  29+ 93EF
  30+ 93EF 7A               ld a,d
  31+ 93F0 E6 02            and %00000010                       ; Extraigo el penúltimo bit de A y lo `traslado´ al último bit de A. El objetivo es implementar una función XOR_
  32+ 93F2 28 02            jr z,2F                             ; _con el último y penúltimo bit de nuestra semilla.
  33+ 93F4
  34+ 93F4 CB 3F            srl a
  35+ 93F6
  36+ 93F6 AB           2 xor e                                 ; XOR entre el último y penúltimo bit de A.
  37+ 93F7
  38+ 93F7 7A               ld a,d                              ; A vuelve a contener la copia de nuestra semilla después del DESPLAZAMIENTO.
  39+ 93F8 28 04            jr z,4F
  40+ 93FA
  41+ 93FA CB FF            set 7,a
  42+ 93FC 18 02            jr 5F
  43+ 93FE
  44+ 93FE CB BF        4 res 7,a
  45+ 9400
  46+ 9400 CB 21        5 sla c
  47+ 9402 10 E0            djnz 6B
  48+ 9404
  49+ 9404 79               ld a,c                              ; Nº aleatorio (1 Byte) en A.
  50+ 9405
  51+ 9405 77               ld (hl),a
  52+ 9406 23               inc hl
  53+ 9407 C1               pop bc
  54+ 9408 10 D4            djnz 3B
  55+ 940A
  56+ 940A C9               ret
  57+ 940B
