   4+ 9605              ;	CLS.
   5+ 9605              ;
   6+ 9605              ;	Limpia la pantalla y define sus atributos.
   7+ 9605              ;	El formato: FBPPPIII (Flash, Brillo, Papel, Tinta).
   8+ 9605              ;
   9+ 9605              ;	COLORES: 0 ..... NEGRO
  10+ 9605              ;    		 1 ..... AZUL
  11+ 9605              ; 			 2 ..... ROJO
  12+ 9605              ;			 3 ..... MAGENTA
  13+ 9605              ; 			 4 ..... VERDE
  14+ 9605              ; 			 5 ..... CIAN
  15+ 9605              ;			 6 ..... AMARILLO
  16+ 9605              ; 			 7 ..... BLANCO
  17+ 9605              ;
  18+ 9605              ;	INPUT: A contiene los atributos de pantalla.
  19+ 9605              ;
  20+ 9605              ;	DESTRUIDOS: F,BC,DE,HL !!!!!
  21+ 9605
  22+ 9605
  23+ 9605 21 00 40     Cls LD HL,$4000											; HL => Comienzo de pantalla.
  24+ 9608 11 01 40     	LD DE,$4001
  25+ 960B 01 00 18     	LD BC,6144											; Tamaño de la pantalla, $17ff
  26+ 960E 36 00        	LD (HL),0 											; Ponemos a "0" todos los pixels de la pantalla.
  27+ 9610 ED B0        	LDIR
  28+ 9612 01 FF 02     	LD BC,767
  29+ 9615 77           	LD (HL),a						 					; Atributos de pantalla, % 00 xxx xxx en [A].
  30+ 9616 ED B0        	LDIR
  31+ 9618 C9           	ret
  32+ 9619
