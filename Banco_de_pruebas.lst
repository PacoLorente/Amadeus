   6+ 999B
   7+ 999B              Draw
   8+ 999B
   9+ 999B CD 41 9C     	call Prepara_draw
  10+ 999E 7C           	ld a,h 						 					; El objeto existe, o se está iniciando?. Si se está iniciando, (Posicion_inicio = Posicion_actual) y saltamos_
  11+ 999F A7           	and a 											; _a la subrutina [Inicializacion] donde asignaremos cuadrante y límites.
  12+ 99A0 28 05        	jr z,2F
  13+ 99A2
  14+ 99A2 3A 09 8C     	ld a,(Cuad_objeto)			 					; El objeto ya se inició. Cargamos en A el cuadrante de pantalla en el que lo hizo y saltamos a 1F.
  15+ 99A5 18 0C        	jr 1F
  16+ 99A7
  17+ 99A7 2A 07 8C     2 ld hl,(Posicion_inicio) 							; No hay (Posicion_actual), por lo que el objeto se está iniciando.
  18+ 99AA 22 FA 8B     	ld (Posicion_actual),hl							; Indicamos que (Posicion_actual) = (Posicion_inicio) y saltamos a la subrutina [Inicializacion], (donde asignaremos_
  19+ 99AD CD 39 9B     	call Inicializacion   							; _(Limite_horizontal), (Limite_vertical) y (Cuad_objeto). También asignaremos las coordenadas X e Y. (Posición 0,0)_
  20+ 99B0              ;													; _la esquina superior izquierda de la pantalla.
  21+ 99B0
  22+ 99B0 CD B9 A0     	call Inicia_Puntero_mov							; El objeto está inicializado. Antes de salir inicializamos tb el puntero de movimiento de la entidad.
  23+ 99B3
  24+ 99B3 3A F7 8B     1 ld a,(Ctrl_0)
  25+ 99B6 CB 6F        	bit 5,a
  26+ 99B8 20 06        	jr nz,3F										; Si acabamos de inicializar un objeto, NO COMPROBAMOS LÍMITES.
  27+ 99BA
  28+ 99BA CD CF 99     	call Comprueba_limite_horizontal
  29+ 99BD CD 5F 9A     	call Comprueba_limite_vertical
  30+ 99C0
  31+ 99C0              ; Llegados a este punto, tengo Filas/Columnas en BC y (Cuad_objeto) en A´.
  32+ 99C0              ; -----------------------
  33+ 99C0              ; -----------------------
  34+ 99C0              ; -----------------------
  35+ 99C0
  36+ 99C0 CD B5 9B     3 call calcula_CColumnass							; Define el valor de la variable (Columnas). Nº de columnas que se van a pintar de la entidad.
  37+ 99C3 CD EC 9B     	call Calcula_puntero_de_impresion				; Después de ejecutar esta rutina tenemos el puntero de impresión en HL.
  38+ 99C6
  39+ 99C6 3A F7 8B     	ld a,(Ctrl_0)									; Antes de salir de la rutina REStauramos el bit5 de Ctrl_0 para que nos vuelva_
  40+ 99C9 CB AF        	res 5,a											; _a ser de utilidad.
  41+ 99CB 32 F7 8B     	ld (Ctrl_0),a
  42+ 99CE
  43+ 99CE C9           	ret
