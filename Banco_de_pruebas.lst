  45+ 99CF              ; *******************************************************************************************************************************************************************************************
  46+ 99CF              ;	21/01/23
  47+ 99CF              ;
  48+ 99CF              ; 	Comprueba_limite_horizontal.
  49+ 99CF              ;
  50+ 99CF              ;	La rutina comprueba si hemos sobrepasado el (Limite_horizontal) definido en la rutina [Inicializacion]. Este será:_
  51+ 99CF              ;	_ $4fc0 si partimos de los cuadrantes 1 o 2 de pantalla o $4820 si partimos de los cuadrantes 3 o 4.
  52+ 99CF              ;
  53+ 99CF              ;	Si sobrepasamos o alcanzamos el límite horizontal establecido, la rutina cargará el registro E con un "1".
  54+ 99CF              ;	Si NO HEMOS SOBREPASADO (Limite_horizontal), E="0".
  55+ 99CF              ;	E="1" indica que HEMOS SOBREPASADO el (Limite_horizontal).
  56+ 99CF              ;	E="2" indica que NO HEMOS SOBREPASADO el (Limite_horizontal) pero hemos alcanzado o superado EL CENTRO DE PANTALLA.
  57+ 99CF
  58+ 99CF
  59+ 99CF
  60+ 99CF 3A F7 8B     Comprueba_limite_horizontal ld a,(Ctrl_0)          	; Si no hemos desaparecido por arriba o por abajo, saltamos a 1F para comprobar_
  61+ 99D2 CB 57        	bit 2,a                                         ; _si hemos llegado o sobrepasado (Limite_horizontal). Seguimos con la rutina.
