  47+ 99A0              ;
  48+ 99A0              ; 	Comprueba_limite_horizontal.
  49+ 99A0              ;
  50+ 99A0              ;	La rutina comprueba si hemos sobrepasado el (Limite_horizontal) definido en la rutina [Inicializacion]. Este será:_
  51+ 99A0              ;	_ $4fc0 si partimos de los cuadrantes 1 o 2 de pantalla o $4820 si partimos de los cuadrantes 3 o 4.
  52+ 99A0              ;
  53+ 99A0              ;	Si sobrepasamos o alcanzamos el límite horizontal establecido, la rutina cargará el registro E con un "1".
  54+ 99A0              ;	Si NO HEMOS SOBREPASADO (Limite_horizontal), E="0".
  55+ 99A0              ;	E="1" indica que HEMOS SOBREPASADO el (Limite_horizontal).
  56+ 99A0              ;	E="2" indica que NO HEMOS SOBREPASADO el (Limite_horizontal) pero hemos alcanzado o superado EL CENTRO DE PANTALLA.
  57+ 99A0
  58+ 99A0
  59+ 99A0
  60+ 99A0 3A F7 8B     Comprueba_limite_horizontal ld a,(Ctrl_0)          	; Si no hemos desaparecido por arriba o por abajo, saltamos a 1F para comprobar_
  61+ 99A3 CB 57        	bit 2,a                                         ; _si hemos llegado o sobrepasado (Limite_horizontal). Seguimos con la rutina.
  62+ 99A5 28 07        	jr z,1F                                         ; Si por el contrario hemos desaparecido por arriba o por abajo, (bit2/bit3 de (Ctrl_0)="1"))_
  63+ 99A7 E6 FB        	and $fb 										; _hay que modificar el puntero de posición. (E="1" y salimos de la rutina). Antes inicializaremos los_
  64+ 99A9 32 F7 8B     	ld (Ctrl_0),a 									; _ bits 2 y 3 de (Ctrl_0).
  65+ 99AC 18 09            jr 6F
  66+ 99AE CB 5F        1 bit 3,a
  67+ 99B0 28 0A            jr z,2F
  68+ 99B2 E6 F7            and $f7
  69+ 99B4 32 F7 8B         ld (Ctrl_0),a
  70+ 99B7 CD 0A 9B     6 call Inicializacion
  71+ 99BA 18 5B            jr 5F
  72+ 99BC E5           2 push hl						        			; Guardo (Posicion_actual), HL en la pila.
  73+ 99BD
  74+ 99BD              ; ----- ----- ----- ----- ----- ----- ----- ----- ----- -----
  75+ 99BD              ; Comprobamos si hemos llegado al (Limite_horizontal). E="0".
  76+ 99BD
  77+ 99BD EB           	ex de,hl 										; Averiguamos si hemos llegado o sobrepasado el (Limite_horizontal). Hemos simplificado la operación SBC_
  78+ 99BE 2A 0B 8C     	ld hl,(Limite_horizontal) 						; _cargando el tercio de pantalla en el byte alto.
  79+ 99C1 CD 9C 95     	call calcula_tercio 							; (Posicion_actual) - (Limite_horizontal).
