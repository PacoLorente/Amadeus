   1+ 95E4              ; *********************************** Limpia la pantalla, CLEAR SCREEN ****************************************************************
   2+ 95E4              ;
   3+ 95E4              ;
   4+ 95E4              ;	CLS.
   5+ 95E4              ;
   6+ 95E4              ;	Limpia la pantalla y define sus atributos.
   7+ 95E4              ;	El formato: FBPPPIII (Flash, Brillo, Papel, Tinta).
   8+ 95E4              ;
   9+ 95E4              ;	COLORES: 0 ..... NEGRO
  10+ 95E4              ;    		 1 ..... AZUL
  11+ 95E4              ; 			 2 ..... ROJO
  12+ 95E4              ;			 3 ..... MAGENTA
  13+ 95E4              ; 			 4 ..... VERDE
  14+ 95E4              ; 			 5 ..... CIAN
  15+ 95E4              ;			 6 ..... AMARILLO
  16+ 95E4              ; 			 7 ..... BLANCO
  17+ 95E4              ;
  18+ 95E4              ;	INPUT: A contiene los atributos de pantalla.
  19+ 95E4              ;
  20+ 95E4              ;	DESTRUIDOS: F,BC,DE,HL !!!!!
  21+ 95E4
  22+ 95E4
  23+ 95E4 21 00 40     Cls LD HL,$4000											; HL => Comienzo de pantalla.
  24+ 95E7 11 01 40     	LD DE,$4001
  25+ 95EA 01 00 18     	LD BC,6144											; Tamaño de la pantalla, $17ff
  26+ 95ED 36 00        	LD (HL),0 											; Ponemos a "0" todos los pixels de la pantalla.
  27+ 95EF ED B0        	LDIR
  28+ 95F1 01 FF 02     	LD BC,767
  29+ 95F4 77           	LD (HL),a						 					; Atributos de pantalla, % 00 xxx xxx en [A].
  30+ 95F5 ED B0        	LDIR
  31+ 95F7 C9           	ret
  32+ 95F8
