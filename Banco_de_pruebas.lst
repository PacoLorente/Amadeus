  13+ 93A3
  14+ 93A3 ED 5F        3 ld a,r      			                ; La semilla inicial de nuestro nº aleatorio la proporciona el registro `R´. Cargamos A con R.
  15+ 93A5 C5               push bc
  16+ 93A6              ;                                       ; El registro R, es un registro de 8 bits que actúa como contador de refresco de la memoria dinámica. ($00 - $ff).
  17+ 93A6 01 00 07         ld bc,$0700                         ; C contendrá nuestro nº aleatorio: $0 - $ff. Inicialmente está a "0".
  18+ 93A9              ;                                       ; B actuará como contador de bits. Requerimos de 1 byte, ($ff).
  19+ 93A9
  20+ 93A9 A7           6 and a                                 ; Carry a "0".
  21+ 93AA CB 3F            srl a                               ; Desplazamiento a la derecha.
  22+ 93AC 30 02            jr nc,1F
  23+ 93AE
  24+ 93AE CB C1            set 0,c
  25+ 93B0
  26+ 93B0 57           1 ld d,a                                ; D contiene la copia de nuestra semilla después del DESPLAZAMIENTO.
  27+ 93B1 E6 01            and %00000001                       ; Extraigo el último bit de A y lo guardamos en E.
  28+ 93B3 5F               ld e,a
  29+ 93B4
  30+ 93B4 7A               ld a,d
  31+ 93B5 E6 02            and %00000010                       ; Extraigo el penúltimo bit de A y lo `traslado´ al último bit de A. El objetivo es implementar una función XOR_
  32+ 93B7 28 02            jr z,2F                             ; _con el último y penúltimo bit de nuestra semilla.
  33+ 93B9
  34+ 93B9 CB 3F            srl a
  35+ 93BB
  36+ 93BB AB           2 xor e                                 ; XOR entre el último y penúltimo bit de A.
  37+ 93BC
  38+ 93BC 7A               ld a,d                              ; A vuelve a contener la copia de nuestra semilla después del DESPLAZAMIENTO.
  39+ 93BD 28 04            jr z,4F
  40+ 93BF
  41+ 93BF CB FF            set 7,a
  42+ 93C1 18 02            jr 5F
  43+ 93C3
  44+ 93C3 CB BF        4 res 7,a
  45+ 93C5
  46+ 93C5 CB 21        5 sla c
  47+ 93C7 10 E0            djnz 6B
  48+ 93C9
  49+ 93C9 79               ld a,c                              ; Nº aleatorio (1 Byte) en A.
  50+ 93CA
  51+ 93CA 77               ld (hl),a
  52+ 93CB 23               inc hl
  53+ 93CC C1               pop bc
  54+ 93CD 10 D4            djnz 3B
