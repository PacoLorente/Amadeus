  11+ 93D0
  12+ 93D0 21 F6 88         ld hl,Numeros_aleatorios
  13+ 93D3
  14+ 93D3 ED 5F        3 ld a,r      			                ; La semilla inicial de nuestro nº aleatorio la proporciona el registro `R´. Cargamos A con R.
  15+ 93D5 C5               push bc
  16+ 93D6              ;                                       ; El registro R, es un registro de 8 bits que actúa como contador de refresco de la memoria dinámica. ($00 - $ff).
  17+ 93D6 01 00 07         ld bc,$0700                         ; C contendrá nuestro nº aleatorio: $0 - $ff. Inicialmente está a "0".
  18+ 93D9              ;                                       ; B actuará como contador de bits. Requerimos de 1 byte, ($ff).
  19+ 93D9
  20+ 93D9 A7           6 and a                                 ; Carry a "0".
  21+ 93DA CB 3F            srl a                               ; Desplazamiento a la derecha.
  22+ 93DC 30 02            jr nc,1F
  23+ 93DE
  24+ 93DE CB C1            set 0,c
  25+ 93E0
  26+ 93E0 57           1 ld d,a                                ; D contiene la copia de nuestra semilla después del DESPLAZAMIENTO.
  27+ 93E1 E6 01            and %00000001                       ; Extraigo el último bit de A y lo guardamos en E.
  28+ 93E3 5F               ld e,a
  29+ 93E4
  30+ 93E4 7A               ld a,d
  31+ 93E5 E6 02            and %00000010                       ; Extraigo el penúltimo bit de A y lo `traslado´ al último bit de A. El objetivo es implementar una función XOR_
  32+ 93E7 28 02            jr z,2F                             ; _con el último y penúltimo bit de nuestra semilla.
  33+ 93E9
  34+ 93E9 CB 3F            srl a
  35+ 93EB
  36+ 93EB AB           2 xor e                                 ; XOR entre el último y penúltimo bit de A.
  37+ 93EC
  38+ 93EC 7A               ld a,d                              ; A vuelve a contener la copia de nuestra semilla después del DESPLAZAMIENTO.
  39+ 93ED 28 04            jr z,4F
  40+ 93EF
  41+ 93EF CB FF            set 7,a
  42+ 93F1 18 02            jr 5F
  43+ 93F3
  44+ 93F3 CB BF        4 res 7,a
  45+ 93F5
  46+ 93F5 CB 21        5 sla c
  47+ 93F7 10 E0            djnz 6B
  48+ 93F9
  49+ 93F9 79               ld a,c                              ; Nº aleatorio (1 Byte) en A.
  50+ 93FA
  51+ 93FA 77               ld (hl),a
  52+ 93FB 23               inc hl
  53+ 93FC C1               pop bc
  54+ 93FD 10 D4            djnz 3B
